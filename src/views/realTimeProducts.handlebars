<header>
<h1>Home - Productos en tiempo real</h1>
</header>

<main>
    <section>
        <h3>Productos</h3>
        <div>
            <ul id="products-list"></ul>
        </div>
    </section>
    <section>
        <h3>Formulario de productos</h3>
        <form id="products-form">
            <input type="text" name="title" placeholder="Ingresa el Nombre">
            <div>
                ¿Esta activo? <input type="checkbox" name="status">
            </div>
            <input type="number" name="stock" placeholder="Ingresa el stock">
            <input type="submit" value="Guardar">
        </form>
    </section>
    <section>
        <h3>Eliminar Articulo</h3>
        <div>
            <input type="number" id="input-product-id">
            <button id="btn-delete-product">Eliminar</button>
        </div>
    </section>
    <p  class="error-message" id="error-message"></p>
</main>

<script src="/socket.io/socket.io.js"></script>
<script src="/api/public/js/products.socket.js"></script>